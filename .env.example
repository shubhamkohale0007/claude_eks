# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=dev                         # dev | staging | prod

# ── AWS ────────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# ── Terraform State Backend ────────────────────────────────────────────────────
TF_STATE_BUCKET=my-company-terraform-state
TF_STATE_DYNAMODB_TABLE=terraform-state-lock

# ── EKS Cluster ────────────────────────────────────────────────────────────────
CLUSTER_NAME=my-eks-dev
CLUSTER_VERSION=1.30

# ── VPC ────────────────────────────────────────────────────────────────────────
VPC_CIDR=10.0.0.0/16
AZS=us-east-1a,us-east-1b,us-east-1c
PUBLIC_SUBNET_CIDRS=10.0.1.0/24,10.0.2.0/24,10.0.3.0/24
PRIVATE_SUBNET_CIDRS=10.0.11.0/24,10.0.12.0/24,10.0.13.0/24
SINGLE_NAT_GATEWAY=true                 # true for dev/staging, false for prod

# ── Security ───────────────────────────────────────────────────────────────────
ENDPOINT_PUBLIC_ACCESS=true
PUBLIC_ACCESS_CIDRS=0.0.0.0/0           # IMPORTANT: prod mein apna IP dalo e.g. 203.0.113.10/32

# ── Node Group ─────────────────────────────────────────────────────────────────
NODE_INSTANCE_TYPE=m5.large
NODE_MIN_SIZE=1
NODE_MAX_SIZE=5
NODE_DESIRED_SIZE=2
NODE_DISK_SIZE=50

# ── Addon Versions ─────────────────────────────────────────────────────────────
COREDNS_VERSION=v1.11.1-eksbuild.4
KUBE_PROXY_VERSION=v1.30.0-eksbuild.3
VPC_CNI_VERSION=v1.18.1-eksbuild.1
ALB_CONTROLLER_CHART_VERSION=1.8.1
CLUSTER_AUTOSCALER_CHART_VERSION=9.37.0
